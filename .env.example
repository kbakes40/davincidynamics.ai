# --- Required (Vinci Telegram + DB) ---
TELEGRAM_BOT_TOKEN=
DATABASE_URL=

# --- Optional: Vinci / site ---
BOOKING_LINK=

# --- BlueBubbles follow-up (Kevin SMS/iMessage) — internal only ---
# When enabled, all three are required at startup.
BLUEBUBBLES_FOLLOWUP_ENABLED=false
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_FROM_HANDLE=

# Delay before sending Kevin follow-up (placeholder in-process timer; use a queue in production).
VINCI_FOLLOWUP_DELAY_MINUTES=5

