# --- OpenClaw Gateway (on-site Leo chat on /ai-team → POST /api/leo-chat; never exposed to browser) ---
# Local OpenClaw defaults to port 18789 (launchd plist + ~/.openclaw/openclaw.json). Match OPENCLAW_BASE_URL.
#
# Start the gateway (config per your install — this repo’s openclaw.yml enables chat completions only):
#   openclaw gateway --config openclaw.yml
# Or with an explicit port:
#   openclaw gateway --port 18789
# Then start this app (`pnpm dev`). Without chatCompletions enabled, POST /v1/chat/completions returns 404/HTML.
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
# Alternative name if you already use OPENCLAW_TOKEN elsewhere:
# OPENCLAW_TOKEN=

# Agent segment for model id openclaw/<id>. "default" is the usual stable alias.
# Note: GET /v1/models is not implemented in many OpenClaw builds (often returns Control UI HTML even when chat works).
OPENCLAW_AGENT_ID=default

# REQUIRED for Leo HTTP fallback: enable OpenAI-compatible HTTP on the gateway.
# In ~/.openclaw/openclaw.json (or equivalent), set:
#   gateway.http.endpoints.chatCompletions.enabled: true
# Optional: gateway.http.endpoints.responses.enabled for POST /v1/responses (this app prefers chat completions when configured).

# Optional: require a lightweight POST /v1/chat/completions preflight before HTTP chat — must be exactly "true".
# GET /v1/models is never used as a gate (HTML there does not mean HTTP is disabled).
# OPENCLAW_HEALTH_CHECK=false

# Optional: skip POST /v1/responses and use only POST /v1/chat/completions (after chat completions are enabled on the gateway).
# OPENCLAW_PREFER_CHAT_COMPLETIONS=true

# --- Anthropic (optional; /api/chat if used elsewhere) ---
ANTHROPIC_API_KEY=

# --- Required (Vinci Telegram + DB) ---
TELEGRAM_BOT_TOKEN=
DATABASE_URL=

# Pause all Supabase/Postgres usage from this app (no pools, no Lead Engine DB). Use while the Supabase project is disconnected.
# DISABLE_SUPABASE_DB=true

# --- Optional: Vinci / site ---
BOOKING_LINK=

# --- BlueBubbles follow-up (Kevin SMS/iMessage) — internal only ---
# When enabled, all three are required at startup.
BLUEBUBBLES_FOLLOWUP_ENABLED=false
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_FROM_HANDLE=

# Delay before sending Kevin follow-up (placeholder in-process timer; use a queue in production).
VINCI_FOLLOWUP_DELAY_MINUTES=5

# Lead Engine: require login for POST /api/leads/export (default: false — same as public GET /api/leads).
# Set to "true" when lead data is sensitive or multi-tenant and exports must match session.
# LEAD_ENGINE_EXPORT_REQUIRE_AUTH=

# Legacy optional Telegram ops ping (not a public handoff; not OpenClaw session routing).
# VINCI_LEO_TELEGRAM_NOTIFY=false
# TELEGRAM_HANDOFF_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
