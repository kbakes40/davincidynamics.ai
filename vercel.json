{
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "rm -rf dist/public && pnpm run build:client",
  "outputDirectory": "dist/public",
  "functions": {
    "api/[[...slug]].ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
