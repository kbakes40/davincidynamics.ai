{
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "rm -rf dist/public && pnpm run build:client",
  "outputDirectory": "dist/public",
  "functions": {
    "api/[[...slug]].ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/lead-engine/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/lead-engine",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
